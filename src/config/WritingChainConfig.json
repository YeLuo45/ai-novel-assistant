{
  "version": "1.0.0",
  "defaultChain": "standard",
  "chains": {
    "standard": [
      {
        "id": "plotting",
        "name": "大纲规划",
        "agent": "PlotExpert",
        "tools": ["PlotTool", "OutlineTool"],
        "input": ["userQuery", "genre"],
        "output": "storyStructure",
        "timeout": 60,
        "retry": 2
      },
      {
        "id": "dialogue",
        "name": "章节撰写",
        "agent": "DialogueMaster",
        "tools": ["WritingTool"],
        "input": ["userQuery", "storyStructure"],
        "output": "chapterDraft",
        "timeout": 90,
        "retry": 2
      },
      {
        "id": "style",
        "name": "风格润色",
        "agent": "StyleGuard",
        "tools": ["StyleTool"],
        "input": ["chapterDraft"],
        "output": "styledContent",
        "timeout": 60,
        "retry": 2
      },
      {
        "id": "review",
        "name": "质量审核",
        "agent": "CriticAgent",
        "tools": ["CriticTool"],
        "input": ["styledContent"],
        "output": "qualityReport",
        "timeout": 45,
        "retry": 1
      }
    ],
    "quick": [
      {
        "id": "quick_write",
        "name": "快速撰写",
        "agent": "DialogueMaster",
        "tools": ["WritingTool"],
        "input": ["userQuery"],
        "output": "chapterDraft",
        "timeout": 90,
        "retry": 1
      },
      {
        "id": "quick_review",
        "name": "快速审核",
        "agent": "CriticAgent",
        "tools": ["CriticTool"],
        "input": ["chapterDraft"],
        "output": "qualityReport",
        "timeout": 30,
        "retry": 1
      }
    ],
    "deep": [
      {
        "id": "plotting",
        "name": "大纲规划",
        "agent": "PlotExpert",
        "tools": ["PlotTool"],
        "input": ["userQuery", "genre"],
        "output": "storyStructure",
        "timeout": 60,
        "retry": 2
      },
      {
        "id": "character_dev",
        "name": "角色专项",
        "agent": "PlotExpert",
        "tools": ["CharacterTool"],
        "input": ["storyStructure"],
        "output": "characterProfile",
        "timeout": 60,
        "retry": 2
      },
      {
        "id": "dialogue",
        "name": "章节撰写",
        "agent": "DialogueMaster",
        "tools": ["WritingTool"],
        "input": ["userQuery", "storyStructure", "characterProfile"],
        "output": "chapterDraft",
        "timeout": 90,
        "retry": 2
      },
      {
        "id": "style",
        "name": "风格润色",
        "agent": "StyleGuard",
        "tools": ["StyleTool"],
        "input": ["chapterDraft"],
        "output": "styledContent",
        "timeout": 60,
        "retry": 2
      },
      {
        "id": "review",
        "name": "质量审核",
        "agent": "CriticAgent",
        "tools": ["CriticTool"],
        "input": ["styledContent"],
        "output": "qualityReport",
        "condition": "contentLength > 2000",
        "timeout": 45,
        "retry": 1
      }
    ]
  },
  "globals": {
    "model": "minimax",
    "temperature": 0.7
  }
}